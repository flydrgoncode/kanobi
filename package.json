{
  "name": "kanobi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@kanobi/web",
    "dev:mobile": "turbo dev --filter=@kanobi/mobile",
    "dev:backend": "turbo dev --filter=@kanobi/backend",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate --filter=@kanobi/backend",
    "db:migrate": "turbo db:migrate --filter=@kanobi/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
